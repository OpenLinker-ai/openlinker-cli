# Public OpenLinker HTTPS origin (no path, query, or credentials).
OPENLINKER_URL=https://openlinker.example

# Shared Worker settings.
OPENLINKER_AGENT_TRANSPORT=auto
OPENLINKER_AGENT_CAPACITY=1
OPENLINKER_AGENT_TIMEOUT_SECONDS=1800

# Codex Runtime Agent. The Agent ID and Agent Token must already exist.
OPENLINKER_CODEX_AGENT_ID=22222222-2222-4222-8222-222222222222
OPENLINKER_CODEX_AGENT_TOKEN=ol_agent_replace_me
CODEX_API_KEY=replace_me
# Optional file alternatives. Never set both a direct value and its _FILE form.
OPENLINKER_CODEX_AGENT_TOKEN_FILE=
CODEX_API_KEY_FILE=
OPENLINKER_CODEX_WORKSPACE=/absolute/path/to/codex-workspace
# Optional: omit to generate and persist /runtime/node-id.
OPENLINKER_CODEX_NODE_ID=
OPENLINKER_CODEX_MODEL=
# Optional OpenAI-compatible Codex API origin/base path; never include credentials.
OPENLINKER_CODEX_BASE_URL=
OPENLINKER_CODEX_WEB_SEARCH=disabled

# Claude Code Runtime Agent.
OPENLINKER_CLAUDE_AGENT_ID=33333333-3333-4333-8333-333333333333
OPENLINKER_CLAUDE_AGENT_TOKEN=ol_agent_replace_me
ANTHROPIC_API_KEY=replace_me
OPENLINKER_CLAUDE_AGENT_TOKEN_FILE=
ANTHROPIC_API_KEY_FILE=
OPENLINKER_CLAUDE_WORKSPACE=/absolute/path/to/claude-workspace
OPENLINKER_CLAUDE_NODE_ID=
OPENLINKER_CLAUDE_MODEL=
OPENLINKER_CLAUDE_WEB_SEARCH=false

# Optional upstream proxy. The egress gateway also accepts the mutually
# exclusive OPENLINKER_EGRESS_UPSTREAM_PROXY_FILE form.
OPENLINKER_EGRESS_UPSTREAM_PROXY=
OPENLINKER_EGRESS_UPSTREAM_PROXY_FILE=
OPENLINKER_EGRESS_DOH_URL=https://1.1.1.1/dns-query
